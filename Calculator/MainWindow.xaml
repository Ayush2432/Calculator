<Window x:Class="Calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Calculator"
        mc:Ignorable="d"
        Title="MainWindow" Height="525" Width="350">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Label  x:Name="resultLabel" 
                Content="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                FontSize="60"
                Grid.ColumnSpan="4"/>
        <Button x:Name="acButton" 
                Content="AC"
                Grid.Row="1"
                FontSize="20" Click="acButton_Click"
                Style="{StaticResource extraButtonStyle}"
                />
        <Button x:Name="negativeButton" 
                Content="+/-"
                Grid.Row="1"
                Grid.Column="1"
                FontSize="20" Click="negativeButton_Click"
                Style="{StaticResource extraButtonStyle}"/>
        <Button x:Name="percentageButton" 
                Content="%"
                Grid.Row="1"
                Grid.Column="2"
                FontSize="20" Click="percentageButton_Click"
                Style="{StaticResource extraButtonStyle}"
                />
        <Button x:Name="divisionButton" 
                Content="/"
                Grid.Row="1"
                Grid.Column="3"
                FontSize="20" 
                Click="operationButton_Click"
                Style="{StaticResource operatorButtonStyle}"
                />
        <Button x:Name="sevenButton" 
                Content="7"
                Grid.Row="2"
                FontSize="20" 
                Click="numbersButton_Click"
                Style="{StaticResource numberButtonStyle}"
                />
        <Button x:Name="eightButton" 
                Content="8"
                Grid.Row="2"
                Grid.Column="1"
                FontSize="20" 
                Click="numbersButton_Click"
                Style="{StaticResource numberButtonStyle}"
                />
        <Button x:Name="nineButton" 
                Content="9"
                Grid.Row="2"
                Grid.Column="2"
                FontSize="20" 
                Click="numbersButton_Click"
                Style="{StaticResource numberButtonStyle}"/>
        <Button x:Name="multiplyButton" 
                Content="*"
                Grid.Row="2"
                Grid.Column="3"
                FontSize="20" 
                Click="operationButton_Click"
                Style="{StaticResource operatorButtonStyle}"
                />
        <Button x:Name="fourButton" 
                Content="4"
                Grid.Row="3"
                FontSize="20" 
                Click="numbersButton_Click"
                Style="{StaticResource numberButtonStyle}"
                />
        <Button x:Name="fiveButton" 
                Content="5"
                Grid.Row="3"
                Grid.Column="1"
                FontSize="20" 
                Click="numbersButton_Click"
                Style="{StaticResource numberButtonStyle}"
                />
        <Button x:Name="sixButton" 
                Content="6"
                Grid.Row="3"
                Grid.Column="2"
                FontSize="20"  
                Click="numbersButton_Click"
                Style="{StaticResource numberButtonStyle}"
                />
        <Button x:Name="substractButton" 
                Content="-"
                Grid.Row="3"
                Grid.Column="3"
                FontSize="20" 
                Click="operationButton_Click"
                Style="{StaticResource operatorButtonStyle}"
                />
        <Button x:Name="oneButton" 
                Content="1"
                Grid.Row="4"
                FontSize="20" 
                Click="numbersButton_Click"
                Style="{StaticResource numberButtonStyle}"
                />
        <Button x:Name="twoButton" 
                Content="2"
                Grid.Row="4"
                Grid.Column="1"
                FontSize="20" Click="numbersButton_Click"
                Style="{StaticResource numberButtonStyle}"
                />
        <Button x:Name="threeButton" 
                Content="3"
                Grid.Row="4"
                Grid.Column="2"
                FontSize="20" Click="numbersButton_Click"
                Style="{StaticResource numberButtonStyle}"
                />
        <Button x:Name="additionButton" 
                Content="+"
                Grid.Row="4"
                Grid.Column="3"
                FontSize="20" 
                Click="operationButton_Click"
                Style="{StaticResource operatorButtonStyle}"
                />
        <Button x:Name="zeroButton" 
                Content="0"
                Grid.Row="5"
                Grid.ColumnSpan="2"
                FontSize="20" Click="numbersButton_Click"
                Style="{StaticResource numberButtonStyle}"
                />
        <Button x:Name="decimalButton" 
                Content="."
                Grid.Row="5"
                Grid.Column="2"
                FontSize="20" Click="decimalButton_Click"
                Style="{StaticResource numberButtonStyle}"
                />
        <Button x:Name="equalsButton" 
                Content="="
                Grid.Row="5"
                Grid.Column="3"
                FontSize="20" 
                Click="equalsButton_Click"
                Style="{StaticResource operatorButtonStyle}"
                />
    </Grid>
</Window>
